# Supabase — required
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your_publishable_anon_key_here

# Recommended for server-side operations (bypasses RLS during pilot)
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Server
PORT=3001
# Public URL of your deployment (used by OpenRouter referrer header)
# APP_URL=https://your-app.example.com

# Telegram — can also be connected via Integrations UI (saved to database)
# TELEGRAM_BOT_TOKEN=123456:ABC...
# Admin chat ID for booking notifications and test button (get from @userinfobot)
# TELEGRAM_CHAT_ID=123456789

# AI responses in Telegram bot
# OPENROUTER_API_KEY=sk-or-...
